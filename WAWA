#include <iostream>
using namespace std;
 
void numeros (){
    int a=0,b=0,c=0;
    
    cout<<"Ingrese A: ";
    cin>>a;
    
    cout<<"Ingrese B: ";
    cin>>b;
    
    cout<<"Ingrese C: ";
    cin>>c;
    
    
    if (a==b && b==c){
        cout<<"Todos los numeros son iguales";
    }
    else if ((a>=b && a<=c) || (a<=b && a>=c)){
        cout<<"A es el numero medio";
    }
    else if
        ((b>=a && b<=c) || (b<=a && b>=c)){
            cout<<"B es el numero medio";
        }
    else if
        ((c>=a && c<=b) || (c<=a && c>=b)){
            cout<<"C es el numero medio";
        }
}

int main (){
    numeros();
    return 0;
}


    b200 = sueldo / 200;
    sueldo = sueldo % 200;

    b100 = sueldo / 100;
    sueldo = sueldo % 100;

    b50 = sueldo / 50;
    sueldo = sueldo % 50;

    b20 = sueldo / 20;
    sueldo = sueldo % 20;

    b10 = sueldo / 10;
    sueldo = sueldo % 10;

    cout << "\nDetalle de billetes:\n";
    cout << "200 Bs: " << b200 << endl;
    cout << "100 Bs: " << b100 << endl;
    cout << "50 Bs: " << b50 << endl;
    cout << "20 Bs: " << b20 << endl;
    cout << "10 Bs: " << b10 << endl;

    if(sueldo > 0){
        cout << "Monto restante no pagado: " << sueldo << " Bs" << endl;
    }
}

int main(){
    pagoSueldo();
    return 0;
}


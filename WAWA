#include <iostream>
using namespace std;

void inversiones(){
    float rendimiento, suma = 0;
    int perdidas = 0, ganancias = 0;

    for(int i = 1; i <= 7; i++){
        cout << "Ingrese rendimiento del dia " << i << ": ";
        cin >> rendimiento;

        suma += rendimiento;

        if(rendimiento < 0){
            perdidas++;
        }

        if(rendimiento > 0){
            ganancias++;
        }
    }

    float promedio = suma / 7;
    float porcentajeGanancia = (float)ganancias * 100 / 7;

    cout << "\nResultado:\n";
    cout << "Dias con perdidas: " << perdidas << endl;
    cout << "Porcentaje de dias con ganancia: " << porcentajeGanancia << "%" << endl;
    cout << "Promedio de rendimiento: " << promedio << endl;
}

int main(){
    inversiones();
    return 0;
}


#include <iostream>
using namespace std;

void controlPedidos(){
    float monto;
    int descuento = 0, invalidos = 0, grandes = 0;

    for(int i = 1; i <= 12; i++){
        cout << "Ingrese monto del pedido " << i << ": ";
        cin >> monto;

        // INVALIDOS
        if(monto < 0 || monto > 3000){
            invalidos++;
        }

        // DESCUENTO (múltiplos de 25)
        if((int)monto % 25 == 0){
            descuento++;
        }

        // GRANDES
        if(monto >= 500 && monto <= 3000){
            grandes++;
        }
    }

    cout << "\nResultado:\n";
    cout << "Pedidos con descuento: " << descuento << endl;
    cout << "Pedidos invalidos: " << invalidos << endl;
    cout << "Pedidos grandes: " << grandes << endl;
}

int main(){
    controlPedidos();
    return 0;
}


    float temp=0, suma=0, promtemperatura=0;
    int tempBajocero=0, criticas=0;
    
    cout<<"Ingresar temperatura:";
    cin>>n;
    
    for(int i=1; i<=n; i++){
        cout<<"Temperaturas"<<i<<": ";
        cin>>temp;
    
    suma+=temp;
    
    if (temp<0){
        tempBajocero++;
    }
    
    if(temp<=-10 || temp>8){
        criticas++;
    }
    
    promtemperatura=suma/n;
    
    cout<<"Temperaturas Bajo Cero:"<<tempBajocero<<endl;
    cout<<"Temperaturas Criticas: "<<criticas<<endl;
    cout<<"Promedio: "<<promtemperatura<<endl;
    
}
}

